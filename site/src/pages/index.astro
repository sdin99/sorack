<!-- ====== FEATURES ====== -->
<section class="block" id="features">
  <div class="wrap">
    <div class="sec-head">
      <div class="left">
        <div class="kicker">features</div>
        <h2>Everything your homelab is, on one canvas.</h2>
        <p>Six primitives that mirror how self-hosted infrastructure actually behaves — no abstractions you have to translate back.</p>
      </div>
    </div>

    <div class="feat-grid">

      <!-- topology -->
      <article class="card">
        <div class="clabel">inventory + topology</div>
        <h3>Edit the graph directly</h3>
        <p>Create, rename, reparent and draw typed edges right on the canvas. dagre lays it out for you, every time.</p>
        <div class="demo">
          <div class="statusline">
            <span class="pill"><span class="dot ok"></span> create</span>
            <span class="pill"><span class="dot ok"></span> reparent</span>
            <span class="pill">typed edge</span>
          </div>
        </div>
      </article>

      <!-- 2-axis model -->
      <article class="card">
        <div class="clabel">two-axis node model</div>
        <h3>Infra × software, merged</h3>
        <p>Every node is an infra type plus zero or more software attachments. Detail and monitoring slots merge across both axes.</p>
        <div class="demo demo-axes">
          <div class="axis-box"><div class="at">infra</div><div class="av">host</div></div>
          <div class="merge">+</div>
          <div class="axis-box"><div class="at">software</div><div class="av">Proxmox VE</div></div>
        </div>
      </article>

      <!-- per-axis monitoring -->
      <article class="card">
        <div class="clabel">per-axis monitoring</div>
        <h3>One probe per axis</h3>
        <p>Infra reachability and software API checks run side by side. StatusLine picks the primary axis and switches to a pill row.</p>
        <div class="demo">
          <div class="gauge-row"><span>cpu</span><b>34%</b></div>
          <div class="gauge"><i style="width:34%"></i></div>
          <div class="statusline" style="margin-top:10px">
            <span class="pill"><span class="dot ok"></span> reachable</span>
            <span class="pill"><span class="dot ok"></span> pve api</span>
          </div>
        </div>
      </article>

      <!-- adapters -->
      <article class="card wide">
        <div class="clabel">built-in adapters</div>
        <h3>Probe anything — adding one is a file and a line</h3>
        <p>Ship with tcp, http, k8s (in-cluster), proxmox (PVE API) and system (node_exporter scrape). A new adapter is a single file plus one register call.</p>
        <div class="demo adapters">
          <span class="chip">tcp</span><span class="chip">http</span><span class="chip">k8s</span>
          <span class="chip">proxmox</span><span class="chip">system</span>
          <span class="chip" style="color:var(--accent); border-color:var(--accent); background:var(--accent-soft)">+ register()</span>
        </div>
      </article>

      <!-- runbooks -->
      <article class="card">
        <div class="clabel">runbooks</div>
        <h3>Markdown, linked to nodes</h3>
        <p>In-app CodeMirror split-view editor, <span class="mono" style="font-size:12px;color:var(--accent)">[[node:]]</span> links, git sync and attachments.</p>
        <div class="demo">
          <div class="runbook-demo">## restart <span class="lnk">[[node:pve-01]]</span><br/>see <span class="lnk">[[runbook:backup]]</span></div>
        </div>
      </article>

    </div>
  </div>
</section>

