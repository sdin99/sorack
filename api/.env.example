# sorack API — environment variables.
# Copy to .env (gitignored) or inject however you deploy (k8s Secret,
# docker -e, etc). The app only reads process.env, so the injection
# method is up to you.

# ── Postgres (required) ──
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=sorack
POSTGRES_USERNAME=sorack
POSTGRES_PASSWORD=change-me

# ── Auth ──
# Pepper mixed into session-token hashes. Generate with:
#   openssl rand -base64 48
# If unset, a random one is generated each boot (sessions won't survive
# a restart — fine for a quick try, set it for anything real).
SORACK_AUTH_SECRET=

# Initial admin. If SORACK_ADMIN_PASSWORD is unset, a random password is
# generated on first boot and printed to the log once.
SORACK_ADMIN_USERNAME=admin
SORACK_ADMIN_PASSWORD=

# Set to "false" only if serving over plain http locally (the session
# cookie is otherwise marked Secure and won't be sent over http).
SORACK_COOKIE_SECURE=true

# Comma-separated list of origins the api will accept cross-origin (with
# credentials). Leave unset for same-origin deployments (the default — what
# a reverse proxy in front of the api produces). Only set this if the web
# UI lives on a different origin than the api.
# SORACK_ALLOWED_ORIGINS=https://dash.example.com,http://localhost:5173

# Optional: API port (default 3001)
# PORT=3001

# ── Health collector ──
# Periodically probes nodes that opt in via meta.probe / meta.softwareProbes
# and writes results to meta.observed.*. Nodes without any probe are never
# touched, so manual status and auto status don't clash.
# SORACK_HEALTH_ENABLED=true          # set "false" to turn the poller off
# SORACK_HEALTH_INTERVAL_MS=30000     # sweep cadence (dev manifest sets 5000)
# SORACK_HEALTH_TIMEOUT_MS=5000       # per-probe timeout (probe.timeoutMs overrides)

# ── Optional adapter credentials ──
# Adapters degrade gracefully when their env isn't set; configure only the
# ones you'll actually use.

# Proxmox VE API token. Mint at PVE → Datacenter → Permissions → API Tokens.
# SORACK_PROXMOX_USER=user@pam!tokenid
# SORACK_PROXMOX_TOKEN=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# SORACK_PROXMOX_INSECURE=true        # if PVE serves a self-signed cert
# SORACK_PROXMOX_HOST=                # fallback when a node has no manual.ip
# SORACK_PROXMOX_NODE=                # fallback PVE node name
